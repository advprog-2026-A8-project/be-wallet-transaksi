# PostgreSQL connection for Wallet service
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=walletdb
POSTGRES_USER=wallet
POSTGRES_PASSWORD=walletpass

# JWT validation for user-facing wallet endpoints
JWT_SECRET=replace-with-the-shared-jwt-secret
JWT_EXPIRATION=86400000

# Midtrans integration
# Leave blank for local flows that do not hit the real payment gateway
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=
MIDTRANS_SNAP_TOKEN_PREFIX=midtrans-snap-
MIDTRANS_SNAP_REDIRECT_BASE_URL=https://snap.midtrans.com/checkout/

# Authentication service lookup integration
# Used to resolve username/email to UUID userId for wallet access policy
AUTH_SERVICE_USERNAME_RESOLVER_ENABLED=true
AUTH_SERVICE_BASE_URL=http://localhost:3002
AUTH_SERVICE_USER_LOOKUP_PATH=/api/profile/lookup
AUTH_SERVICE_TIMEOUT_MS=1000

# Order service callback publisher
# Used when wallet publishes payment settled/failed back to Order service
ORDER_SERVICE_PUBLISHER_ENABLED=false
ORDER_SERVICE_BASE_URL=http://localhost:5002
ORDER_SERVICE_TIMEOUT_MS=1000
ORDER_SERVICE_PAYMENT_SETTLED_PATH=/internal/orders/payment/settled
ORDER_SERVICE_PAYMENT_FAILED_PATH=/internal/orders/payment/failed
ORDER_SERVICE_INTERNAL_AUTHORIZATION=

# Internal gRPC server for Order -> Wallet contract calls
# GRPC_SERVER_INTERNAL_TOKEN must match the token configured in Order service
GRPC_SERVER_ENABLED=false
GRPC_SERVER_PORT=9090
GRPC_SERVER_INTERNAL_TOKEN=replace-with-shared-internal-grpc-token

# Observability / Actuator
# Enable these when running Prometheus/Grafana monitoring
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
MANAGEMENT_ENDPOINT_PROMETHEUS_ACCESS=none
MANAGEMENT_PROMETHEUS_METRICS_EXPORT_ENABLED=false
